# HUB - Configuracao de implantacao
# Variaveis usadas pelos scripts .bat - ajuste conforme o ambiente
# Linhas com # sao ignoradas

# === Portas (globais - usadas por deploy, IIS, .env.example) ===
# Frontend: 10301 | Backend: 10302 (faixa 10k - projeto 3)
FRONTEND_PORT=10301
BACKEND_PORT=10302

# BACKEND_URL: usado no web.config (proxy /api). Se vazio, usa http://localhost:BACKEND_PORT

# Caminho base da aplicacao (backend, packages)
BASE_PATH=D:\IMPLANTACAO\hub\app

# Caminho do frontend buildado (dist). Se vazio, usa BASE_PATH\frontend\dist
# Use quando frontend esta em pasta separada (ex: web\v2)
FRONTEND_PATH=D:\IMPLANTACAO\hub\frontend

# Caminho do diretorio virtual appjaspi (pode estar fora do BASE_PATH)
APPJASPI_PATH=D:\IMPLANTACAO\hub\appjaspi

# IIS - Application Pool
APPPOOL_NAME=HubAppPool

# IIS - Site dedicado (nao usa Default Web Site)
SITE_NAME=HUB

# Diretorio virtual appjaspi (sob o site)
VDIR_NAME=appjaspi

# CD - Pasta onde baixar/guardar zips de update (usado no download automatico)
RELEASES_PATH=D:\IMPLANTACAO\hub\infra

# Repositorio GitHub (owner/repo) para buscar ultima release
GITHUB_REPO=jaspisistemas/hub